# Python / runtime
# ==========================================
__pycache__/
*.pyc
src/*.egg-info/

# ==========================================
# Jupyter (global safety)
# ==========================================
.ipynb_checkpoints/**

# ==========================================
# SLURM / cluster outputs
# ==========================================
*.out
*.err
*.log

